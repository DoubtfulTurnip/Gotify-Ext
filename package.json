{
  "name": "gotify-ext",
  "version": "0.4.2",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "build:xpi": "ng build --configuration production && node build-xpi.js",
    "prod": "ng build --configuration production && cp ./src/manifest.prod.json ./dist/gotify-ext/manifest.json && sed -i -e \"s/{|vers|}/$(git describe --tags --abbrev=0 | cut -c 2-)/g\" ./dist/gotify-ext/manifest.json && cd ./dist/gotify-ext && zip -r gotify-ext-dist.zip ./*",
    "deploy": "npm run prod && ./deploy.fish",
    "test": "ng test",
    "src-zip": "zip -r gotify-ext-src ./* -x 'node_modules/*' '.git/*' 'gotify_dev/gotify/*' 'dist/*' 'deploy.fish'",
    "audit": "npm audit --audit-level=high"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "21.2.18",
    "@angular/cdk": "21.2.14",
    "@angular/common": "21.2.18",
    "@angular/compiler": "21.2.18",
    "@angular/core": "21.2.18",
    "@angular/forms": "21.2.18",
    "@angular/material": "21.2.14",
    "@angular/platform-browser": "21.2.18",
    "@angular/platform-browser-dynamic": "21.2.18",
    "@angular/router": "21.2.18",
    "@fortawesome/angular-fontawesome": "4.0.0",
    "@fortawesome/fontawesome-svg-core": "7.1.0",
    "@fortawesome/free-solid-svg-icons": "7.1.0",
    "ngx-scrollbar": "19.1.5",
    "ngx-toastr": "20.0.5",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.16.0"
  },
  "devDependencies": {
    "@angular-builders/custom-webpack": "21.1.0",
    "@angular-devkit/build-angular": "21.2.19",
    "@angular/cli": "21.2.19",
    "@angular/compiler-cli": "21.2.18",
    "@angular/language-service": "21.2.18",
    "@types/chrome": "0.1.32",
    "@types/jasmine": "5.1.9",
    "@types/node": "22.18.0",
    "chrome-webstore-upload-cli": "3.5.0",
    "jasmine-core": "5.11.0",
    "karma": "6.4.4",
    "karma-chrome-launcher": "3.2.0",
    "karma-coverage": "2.2.1",
    "karma-jasmine": "5.1.0",
    "karma-jasmine-html-reporter": "2.1.0",
    "typescript": "5.9.3"
  }
}
